{
  "name": "@exortek/shared",
  "version": "0.0.0",
  "description": "Private workspace utilities shared across @exortek/* packages. Never published — consumers inline via bundler.",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./encoding/base64url": "./src/encoding/base64url.js",
    "./time/duration": "./src/time/duration.js",
    "./crypto/hash": "./src/crypto/hash.js",
    "./crypto/hmac": "./src/crypto/hmac.js",
    "./crypto/random": "./src/crypto/random.js",
    "./crypto/timing-safe": "./src/crypto/timing-safe.js",
    "./concurrency/mutex": "./src/concurrency/mutex.js",
    "./polymorphic": "./src/polymorphic.js",
    "./signing/algorithms": "./src/signing/algorithms.js",
    "./signing/ecdsa": "./src/signing/ecdsa.js",
    "./validate": "./src/validate/schema.js"
  },
  "scripts": {
    "build": "echo 'shared has no build step — source consumed via bundler inline'",
    "test": "node --test 'tests/**/*.test.js'",
    "typecheck": "echo 'no build, no typecheck'",
    "prepack": "cp ../../LICENSE ./LICENSE"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
