{
  "name": "@exortek/shared",
  "version": "0.0.0",
  "description": "Private workspace utilities shared across @exortek/* packages. Never published — consumers inline via bundler.",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./base64url": "./src/base64url.js",
    "./duration": "./src/duration.js",
    "./hash": "./src/hash.js",
    "./hmac": "./src/hmac.js",
    "./random": "./src/random.js",
    "./timing-safe": "./src/timing-safe.js",
    "./mutex": "./src/mutex.js",
    "./resolve": "./src/resolve.js",
    "./validate": "./src/validate.js",
    "./algorithms": "./src/algorithms.js",
    "./crit": "./src/crit.js",
    "./ecdsa": "./src/ecdsa.js"
  },
  "scripts": {
    "build": "echo 'shared has no build step — source consumed via bundler inline'",
    "test": "node --test 'tests/**/*.test.js'",
    "typecheck": "echo 'no build, no typecheck'",
    "prepack": "cp ../../LICENSE ./LICENSE"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
