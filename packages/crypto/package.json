{
  "name": "@exortek/crypto",
  "version": "0.0.1",
  "description": "Zero-dependency cryptographic primitives for Node.js — hash / hmac / KDFs (PBKDF2, HKDF, scrypt), AES-GCM / ChaCha20-Poly1305 / RSA-OAEP ciphers, RS/PS/ES/EdDSA signatures, signed cookies, sealed timed tokens, CSPRNG (UUID v4/5/7, ULID, base58, crockford), and encoders — all built on node:crypto.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./hash": {
      "types": "./dist/hash/index.d.ts",
      "import": "./dist/hash.mjs",
      "require": "./dist/hash.cjs"
    },
    "./cipher": {
      "types": "./dist/cipher/index.d.ts",
      "import": "./dist/cipher.mjs",
      "require": "./dist/cipher.cjs"
    },
    "./sign": {
      "types": "./dist/sign/index.d.ts",
      "import": "./dist/sign.mjs",
      "require": "./dist/sign.cjs"
    },
    "./binary": {
      "types": "./dist/binary/index.d.ts",
      "import": "./dist/binary.mjs",
      "require": "./dist/binary.cjs"
    },
    "./encode": {
      "types": "./dist/encode/index.d.ts",
      "import": "./dist/encode.mjs",
      "require": "./dist/encode.cjs"
    },
    "./random": {
      "types": "./dist/random/index.d.ts",
      "import": "./dist/random.mjs",
      "require": "./dist/random.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.js && tsc -p tsconfig.json",
    "build:watch": "rollup -c rollup.config.js --watch",
    "build:types": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test 'tests/**/*.test.js'",
    "test:coverage": "node --test --experimental-test-coverage 'tests/**/*.test.js'",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "auth",
    "crypto",
    "hash",
    "sha256",
    "sha3",
    "blake2",
    "hmac",
    "signed-cookie",
    "cipher",
    "aes",
    "aes-gcm",
    "chacha20-poly1305",
    "rsa",
    "rsa-oaep",
    "ecdh",
    "x25519",
    "sign",
    "ecdsa",
    "ed25519",
    "eddsa",
    "jwt",
    "jwk",
    "thumbprint",
    "pbkdf2",
    "hkdf",
    "scrypt",
    "passphrase",
    "seal",
    "fingerprint",
    "random",
    "uuid",
    "uuid4",
    "uuid7",
    "ulid",
    "base32",
    "base58",
    "base64url",
    "crockford",
    "csprng",
    "zero-dependency",
    "node-crypto"
  ],
  "license": "MIT",
  "homepage": "https://github.com/ExorTek/auth/tree/master/packages/crypto#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ExorTek/auth.git",
    "directory": "packages/crypto"
  },
  "bugs": {
    "url": "https://github.com/ExorTek/auth/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
