# Dependencies
node_modules/

# Build artifacts
dist/
*.tsbuildinfo
**.next/
web/public/_pagefind/

# Yarn (Berry) — keep cache/install state out
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Coverage
coverage/
.nyc_output/
lcov.info

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Env
.env
.env.*
!.env.example

# npm pack output (yarn npm pack, yarn pack)
*.tgz

# Publish-time backup files (strip-workspace-devdeps.js)
*.prepublish

# Claude Code / personal working notes
/.claude
skills-lock.json
ARCHITECTURE-local.md
CLAUDE.md
PLAN.md
REPORT.md
/scripts/deprecate.sh

# LICENSE files are generated per-package at `npm pack` time from root LICENSE
# via each package's `prepack` script — do not track the copies.
packages/*/LICENSE
